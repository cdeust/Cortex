{
  "name": "cortex",
  "description": "Persistent memory and cognitive profiling for Claude Code — thermodynamic memory with heat/decay, intent-aware retrieval, biological plasticity, and cognitive profiling that learns how you work. 34 MCP tools across memory storage, recall, knowledge graph navigation, cognitive profiling, visualization, and automation.",
  "version": "2.2.0",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/Cortex",
  "repository": "https://github.com/cdeust/Cortex",
  "license": "MIT",
  "keywords": ["memory", "cognitive-profiling", "mcp", "claude-code", "neuroscience", "knowledge-graph"],
  "mcpServers": {
    "cortex": {
      "command": "python3",
      "args": ["-m", "mcp_server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/pyproject.toml\" \"${CLAUDE_PLUGIN_DATA}/pyproject.toml\" >/dev/null 2>&1 || (cp \"${CLAUDE_PLUGIN_ROOT}/pyproject.toml\" \"${CLAUDE_PLUGIN_DATA}/\" && pip install -e \"${CLAUDE_PLUGIN_ROOT}\") || rm -f \"${CLAUDE_PLUGIN_DATA}/pyproject.toml\""
          },
          {
            "type": "command",
            "command": "python3 -m mcp_server.hooks.session_start",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m mcp_server.hooks.session_lifecycle",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m mcp_server.hooks.post_tool_capture",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compaction",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m mcp_server.hooks.compaction_checkpoint",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ]
  }
}
