{
  "name": "cortex",
  "description": "Persistent memory and cognitive profiling for Claude Code — thermodynamic memory with heat/decay, intent-aware retrieval, biological plasticity, codebase intelligence, and cognitive profiling. 35 MCP tools. Docker image available with PostgreSQL + pgvector pre-configured.",
  "version": "2.5.5",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/Cortex",
  "repository": "https://github.com/cdeust/Cortex",
  "license": "MIT",
  "keywords": ["memory", "cognitive-profiling", "mcp", "claude-code", "neuroscience", "knowledge-graph"],
  "mcpServers": {
    "cortex": {
      "command": "python3",
      "args": ["-m", "mcp_server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import fastmcp\" 2>/dev/null || python3 -m pip install -q --target \"${CLAUDE_PLUGIN_DATA}/deps\" fastmcp pydantic pydantic-settings numpy 2>/dev/null; PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.session_start",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.session_lifecycle",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.post_tool_capture",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compaction",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.compaction_checkpoint",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ]
  }
}
