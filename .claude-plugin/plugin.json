{
  "name": "cortex",
  "description": "Persistent memory for Claude Code — remembers across sessions automatically. Install and forget. Scientific retrieval backed by 41 published papers.",
  "version": "3.2.0",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/Cortex",
  "repository": "https://github.com/cdeust/Cortex",
  "license": "MIT",
  "keywords": ["memory", "persistent", "mcp", "claude-code", "neuroscience", "agents"],
  "mcpServers": {
    "cortex": {
      "command": "python3",
      "args": ["-m", "mcp_server"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import psycopg\" 2>/dev/null || python3 -m pip install -q --target \"${CLAUDE_PLUGIN_DATA}/deps\" fastmcp pydantic pydantic-settings numpy \"psycopg[binary]>=3.1\" \"pgvector>=0.3\" \"sentence-transformers>=2.2.0\" \"flashrank>=0.2.0\" 2>/dev/null; PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.session_start",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.auto_recall",
            "timeout": 3,
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.post_tool_capture",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          },
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.preemptive_context",
            "timeout": 3,
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.session_lifecycle",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compaction",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.compaction_checkpoint",
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}:${CLAUDE_PLUGIN_DATA}/deps\" python3 -m mcp_server.hooks.agent_briefing",
            "timeout": 5,
            "cwd": "${CLAUDE_PLUGIN_ROOT}"
          }
        ]
      }
    ]
  }
}
