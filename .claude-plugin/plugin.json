{
  "name": "cortex",
  "description": "Persistent memory for Claude Code — remembers across sessions automatically. Install and forget. Scientific retrieval backed by 41 published papers.",
  "version": "3.13.0",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/Cortex",
  "repository": "https://github.com/cdeust/Cortex",
  "license": "MIT",
  "keywords": ["memory", "persistent", "mcp", "claude-code", "neuroscience", "agents"],
  "mcpServers": {
    "cortex": {
      "command": "uvx",
      "args": ["--python", "3.13", "--from", "neuro-cortex-memory[postgresql]", "neuro-cortex-memory"],
      "env": {
        "DATABASE_URL": "postgresql://localhost:5432/cortex",
        "CORTEX_RUNTIME": ""
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook session_start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook auto_recall",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook post_tool_capture",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook preemptive_context",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook session_lifecycle",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "compacted",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook compaction_checkpoint",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --python 3.13 --from 'neuro-cortex-memory[postgresql]' cortex-hook agent_briefing",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
